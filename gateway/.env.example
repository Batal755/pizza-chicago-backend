# HTTP-порт шлюза
PORT=4000

# Разрешённый источник для CORS (фронтенд)
WEB_ORIGIN=http://localhost:3000

# Секрет для проверки access-токена.
# ВАЖНО: значение обязано совпадать с JWT_ACCESS_SECRET в services/auth-service/.env
JWT_ACCESS_SECRET=dev_shared_access_secret_change_in_prod

# Адреса gRPC-микросервисов
AUTH_GRPC_URL=localhost:50051
CATALOG_GRPC_URL=localhost:50052
ORDERS_GRPC_URL=localhost:50053
SUPPORT_GRPC_URL=localhost:50054
NOTIFICATIONS_GRPC_URL=localhost:50055
PAYMENT_GRPC_URL=localhost:50056

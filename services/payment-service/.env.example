# gRPC-адрес микросервиса оплаты
GRPC_URL=0.0.0.0:50056

# Подключение к базе данных payment_db
DATABASE_URL="postgresql://pizza:pizza@localhost:5432/payment_db?schema=public"

# Ключи ЮKassa (YooKassa). В режиме MOCK не требуются.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Режим MOCK: true — работаем без реальных вызовов ЮKassa (фейковые платежи).
PAYMENT_MOCK=true

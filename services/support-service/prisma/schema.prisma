// Prisma-схема support-service: обращения в поддержку с сайта

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Статус обращения в поддержку
enum TicketStatus {
  OPEN
  CLOSED
}

// Обращение пользователя в поддержку
model SupportTicket {
  id        String       @id @default(cuid())
  userId    String?
  name      String
  contact   String
  message   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
}

// Prisma-схема auth-service: пользователи и их роли

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Роли пользователей системы
enum Role {
  CUSTOMER
  ADMIN
}

// Пользователь пиццерии
model User {
  id           String   @id @default(cuid())
  name         String
  phone        String   @unique
  email        String?  @unique
  passwordHash String
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())
}

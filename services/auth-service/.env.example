# Подключение к базе данных auth_db
DATABASE_URL="postgresql://pizza:pizza@localhost:5432/auth_db?schema=public"

# gRPC-адрес микросервиса
GRPC_URL=0.0.0.0:50051

# Секреты JWT (в проде задать собственные длинные случайные значения).
# ВАЖНО: JWT_ACCESS_SECRET обязан совпадать со значением в gateway/.env —
# им auth-service подписывает токен, а шлюз его проверяет.
JWT_ACCESS_SECRET=dev_shared_access_secret_change_in_prod
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_prod

# Время жизни токенов
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

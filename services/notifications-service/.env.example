# gRPC-адрес микросервиса уведомлений
GRPC_URL=0.0.0.0:50055

# Режим без реальной отправки: логируем в консоль и считаем успехом.
# Удобно для демо/разработки без настройки SMTP и SMS-провайдера.
NOTIFY_MOCK=true

# --- Email (SMTP) ---
# Если хотя бы один из SMTP_HOST/SMTP_USER/SMTP_PASS не задан — email уходит в mock-режим.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Pizza Chicago <no-reply@pizza-chicago.example>"

# --- SMS ---
# Если SMS_PROVIDER_URL или SMS_API_KEY не задан — SMS уходит в mock-режим.
SMS_PROVIDER_URL=
SMS_API_KEY=
SMS_SENDER=PizzaChicago
